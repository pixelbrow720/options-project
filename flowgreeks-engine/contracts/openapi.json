","items":{"$ref":"#/components/schemas/AccessRequestSummary"},"title":"Response List Access Requests Admin Access Requests Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/access-requests/{user_id}/approve":{"post":{"tags":["admin"],"summary":"Approve Access Request","description":"Approve a pending user.\n\nIf ``api_key_id`` is supplied, that existing key is bridged to the\nuser. Otherwise a fresh key is generated, labelled\n``Public-{discord_username}``, with the requested or default\n``allowed_symbols``. The plaintext key is returned exactly once.","operationId":"approve_access_request_admin_access_requests__user_id__approve_post","security":[{"HTTPBearer":[]}],"parameters":[{"name":"user_id","in":"path","required":true,"schema":{"type":"integer","title":"User Id"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AccessApproveRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AccessApproveResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/admin/access-requests/{user_id}/reject":{"post":{"tags":["admin"],"summary":"Reject Access Request","operationId":"reject_access_request_admin_access_requests__user_id__reject_post","security":[{"HTTPBearer":[]}],"parameters":[{"name":"user_id","in":"path","required":true,"schema":{"type":"integer","title":"User Id"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AccessRejectRequest"}}}},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PublicUserSummary"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/compo