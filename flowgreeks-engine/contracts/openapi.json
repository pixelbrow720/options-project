{"openapi":"3.1.0","info":{"title":"Options Flow Analytics Platform","version":"0.1.0"},"paths":{"/health":{"get":{"summary":"Health","operationId":"health_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Health Health Get"}}}}}}},"/v1/{symbol}/snapshot":{"get":{"summary":"Get Snapshot","operationId":"get_snapshot_v1__symbol__snapshot_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/0dte":{"get":{"summary":"Get Zero Dte","description":"Rev 4 — thin envelope around the 0DTE + back-month cohorts.\n\nReturns the same data the snapshot would, but filtered down to the\nRev 4 0DTE-first fields so the 0DTE-focused page can fetch a\nsmaller payload. ``session_state`` is included so the front-end can\nshow the RTH banner without a second roundtrip.","operationId":"get_zero_dte_v1__symbol__0dte_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/spot":{"get":{"summary":"Get Spot","description":"Rev 4 — standalone spot resolution endpoint.\n\nUseful for the dashboard's spot-source badge and for downstream\nconsumers that only need the current spot price plus its\nprovenance (``futures_basis`` / ``parity`` / ``stale_cache``).","operationId":"get_spot_v1__symbol__spot_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/futures-levels":{"get":{"summary":"Get Futures Levels","description":"Rev 4 — SpotGamma-style key levels translated into futures space.\n\nThe chain that drives Zero Gamma / Call Wall / Put Wall / Max Pain\n/ top GEX strikes is in cash index space (SPXW / NDXP). Most of our\nusers trade the corresponding CME future (ES / NQ), so this endpoint\ntranslates every level into futures coordinates using the EMA basis\npersisted by the spot resolver: ``futures_level = cash_strike - basis``.\n\nWhen the futures feed is offline (no ``basis`` or ``futures_price``)\nthe response still includes the cash levels with ``futures_level``\nset, but ``distance_pts`` / ``distance_pct`` are ``None`` so the\nfront-end can render a \"futures feed offline\" banner.","operationId":"get_futures_levels_v1__symbol__futures_levels_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/stream/sse":{"get":{"summary":"Stream Sse","description":"Server-Sent Events fallback for clients that cannot use WebSockets.","operationId":"stream_sse_v1__symbol__stream_sse_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/flow":{"get":{"summary":"Get Flow","description":"Return detected flow events ordered by ``ts`` descending.\n\nFilters: ``event_type`` (``SWEEP`` / ``BLOCK`` / ``UOA`` / ``all``),\n``since`` (default: last 1 hour), ``limit`` (default: 100, max 1000).","operationId":"get_flow_v1__symbol__flow_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"event_type","in":"query","required":false,"schema":{"type":"string","default":"all","title":"Event Type"}},{"name":"since","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Since"}},{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":1000,"minimum":1,"default":100,"title":"Limit"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Get Flow V1  Symbol  Flow Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/hiro":{"get":{"summary":"Get Hiro","description":"Return the HIRO cumulative signed-premium series for ``symbol``.\n\nThe persisted series uses 1-minute buckets; ``5m`` / ``15m`` are\nre-aggregated server-side. ``since`` defaults to the last 1 hour.","operationId":"get_hiro_v1__symbol__hiro_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"bucket","in":"query","required":false,"schema":{"type":"string","pattern":"^(1m|5m|15m)$","default":"1m","title":"Bucket"}},{"name":"since","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date-time"},{"type":"null"}],"title":"Since"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Get Hiro V1  Symbol  Hiro Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/gex":{"get":{"summary":"Get Gex","operationId":"get_gex_v1__symbol__gex_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"mode","in":"query","required":false,"schema":{"type":"string","pattern":"^(oi|volume)$","default":"oi","title":"Mode"}},{"name":"expiry","in":"query","required":false,"schema":{"type":"string","default":"all","title":"Expiry"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope_GexResponse_"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/max-pain":{"get":{"summary":"Get Max Pain","operationId":"get_max_pain_v1__symbol__max_pain_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"expiry","in":"query","required":false,"schema":{"type":"string","minLength":1,"maxLength":10,"default":"nearest","title":"Expiry"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope_MaxPainResponse_"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/v1/{symbol}/walls":{"get":{"summary":"Get Walls","operationId":"get_walls_v1__symbol__walls_get","parameters":[{"name":"symbol","in":"path","required":true,"schema":{"type":"string","minLength":1,"maxLength":20,"pattern":"^[A-Za-z0-9_.-]+$","title":"Symbol"}},{"name":"mode","in":"query","required":false,"schema":{"type":"string","pattern":"^(oi|volume|both)$","default":"both","title":"Mode"}},{"name":"X-API-Key","in":"header","required":false,"schema":{"anyOf":[{"type":"string"},{"type":"null"}],"title":"X-Api-Key"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DataEnvelope_WallsResponse_"}}}},"422":{"description":"Valid