,"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","title":"Response Data Inspector Admin Inspector Get"}}}}},"security":[{"HTTPBearer":[]}]}},"/admin/inspector/dlq":{"get":{"tags":["admin"],"summary":"Dlq Inspector","description":"Paginated read-only view of the dead-letter queue.\n\n``limit`` defaults to 50 and is capped at 500; ``offset`` defaults to 0.\nOut-of-range values return ``422 Unprocessable Entity`` via FastAPI's\nbuilt-in query-param validation (``gt=0``, ``le=500``, ``ge=0``).","operationId":"dlq_inspector_admin_inspector_dlq_get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"limit","in":"query","required":false,"schema":{"type":"integer","maximum":500,"exclusiveMinimum":0,"default":50,"title":"Limit"}},{"name":"offset","in":"query","required":false,"schema":{"type":"integer","minimum":0,"default":0,"title":"Offset"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DlqPage"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/public/auth/discord/start":{"get":{"tags":["public-auth"],"summary":"Discord Start","description":"Return the URL to redirect the browser to to begin the OAuth flow.","operationId":"discord_start_public_auth_discord_start_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DiscordStartResponse"}}}}}}},"/public/auth/discord/callback":{"get":{"tags":["public-auth"],"summary":"Discord Callback","description":"Exchange the Discord OAuth code, upsert the user, return a session JWT.\n\nResponse shapes:\n  * 200 + :class:`PublicSessionResponse` — user is approved + guild\n    verified; session JWT issued.\n  * 403 + :class:`AccessPendingResponse` — user not yet approved (or\n    not in the guild). The body includes the invite URL and contact\n    handles so the public site can render a friendly waiting page.\n  * 400 — ``state`` did not validate.\n  * 502 — Discord upstream rejected the request.","operationId":"discord_callback_public_auth_discord_callback_get","parameters":[{"name":"code","in":"query","required":true,"schema":{"type":"string","title":"Code"}},{"name":"state","in":"query","required":true,"schema":{"type":"string","title":"State"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/public/auth/login":{"post":{"tags":["public-auth"],"summary":"Login With Api Key","description":"Trade an admin-issued API key for a public-session JWT.\n\nUsed by users with a key issued before Discord OAuth was wired up.\nThe bridged user row is marked ``guild_verified=False`` so admins\ncan see who came in through this path.","operationId":"login_with_api_key_public_auth_login_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/PublicLoginRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PublicSessionResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/public/me":{"get":{"tags":["public-auth"],"summary":"Get Me","operationId":"get_me_public_me_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/PublicMeResponse"}}}}},"security":[{"HTTPBearer":[]}]}},"/public/auth/logout":{"post":{"tags":["public-auth"],"summary":"Logout","description":"Mark the bearer's ``user_sessions`` row as revoked.\n\nIdempotent — silently succeeds even when the token is already\nexpired or has been revoked, s