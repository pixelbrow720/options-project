# ──────────────────────────────────────────────────────────────────────
# Repo-root .gitignore for the pantek-waang options analytics project
# ──────────────────────────────────────────────────────────────────────

# ── Python (backend) ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.venv/
venv/
env/
ENV/

# ── Node / Vite / TypeScript (frontend, public-site) ──────────────────
node_modules/
dist/
.vite/
.parcel-cache/
.next/
.turbo/
*.tsbuildinfo
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Env files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.*.local
*.env
backend/.env
frontend/.env
public-site/.env
# Allow templates / examples
!.env.example
!.env.sample
!*.env.example

# ── Editors / IDEs ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# ── OS noise ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── AI assistants / agents ────────────────────────────────────────────
.claude/
.cursor/
.windsurf/
.continue/

# ── Docker ────────────────────────────────────────────────────────────
.docker/

# ── Local data / databases ────────────────────────────────────────────
data/
*.sqlite
*.sqlite3
*.db

# ── Archives (don't commit zip dumps of the project) ──────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ── Misc temp / backup ────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.pid
