{
  "name": "flowgreeks-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "FlowGreeks SPA — options-flow trading dashboard. Consumes flowgreeks-engine REST + WS contracts.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome check src tests scripts",
    "lint:fix": "biome check --write src tests scripts",
    "format": "biome format --write src tests scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build -o storybook-static",
    "sync:contracts": "tsx scripts/sync-contracts.ts"
  },
  "dependencies": {
    "@react-three/drei": "9.122.0",
    "@react-three/fiber": "8.18.0",
    "@react-three/postprocessing": "2.19.1",
    "@tanstack/react-query": "5.90.3",
    "@tanstack/react-query-devtools": "5.90.3",
    "clsx": "2.1.1",
    "framer-motion": "11.18.2",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.0",
    "tailwind-merge": "2.6.0",
    "three": "0.170.0",
    "uplot": "1.6.32",
    "zustand": "5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@playwright/test": "1.49.1",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@tailwindcss/postcss": "4.0.0",
    "@tailwindcss/vite": "4.0.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.10.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "0.170.0",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1",
    "postcss": "8.5.0",
    "storybook": "8.6.14",
    "tailwindcss": "4.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vite": "7.0.0",
    "vite-plugin-glsl": "1.3.1",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@9.15.4"
}
