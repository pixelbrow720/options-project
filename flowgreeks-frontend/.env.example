# Backend REST base URL (no trailing slash). All /v1/* and /admin/* routes
# resolve relative to this. In dev: typically http://127.0.0.1:8000.
VITE_API_BASE_URL=http://127.0.0.1:8000

# WebSocket base URL. Same host as API in most deployments. Use ws:// for
# local dev, wss:// for staging/prod.
VITE_WS_BASE_URL=ws://127.0.0.1:8000

# Optional: enable React Query devtools floating button in dev builds.
VITE_ENABLE_QUERY_DEVTOOLS=true

# Optional: bypass the login screen in local dev by injecting a fixed key.
# NEVER set this in production. The token must be present in the local
# admin DB; it is read from VITE-prefixed env at build time and exposed to
# the client. Treat as a developer convenience only.
# VITE_DEV_API_KEY=ak_localdev_xxx

# Optional: log all WS frames at debug level (very chatty).
VITE_WS_DEBUG=false
