# ──────────────────────────────────────────────────────────────────────
# Project-local .gitignore for pantek-waang
# (the repo-root .gitignore covers the parent layout; this one keeps the
#  project self-contained if checked out on its own)
# ──────────────────────────────────────────────────────────────────────

# ── Python (backend) ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.venv/
venv/
env/
ENV/

# ── Node / Vite / TypeScript ──────────────────────────────────────────
node_modules/
dist/
.vite/
.parcel-cache/
.next/
.turbo/
*.tsbuildinfo
.eslintcache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Env files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
backend/.env
frontend/.env
!.env.example
!.env.sample
!*.env.example

# ── Editors / OS ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── AI assistants ─────────────────────────────────────────────────────
.claude/
.cursor/
.windsurf/

# ── Docker / data ─────────────────────────────────────────────────────
.docker/
data/
*.sqlite
*.sqlite3
*.db

# ── Archives ──────────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ── Misc ──────────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.pid
